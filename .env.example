# ── Local dev ─────────────────────────────────────────────────────────────
POSTGRES_DB=air_ops
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me

# ── Production (Render) ───────────────────────────────────────────────────
# DATABASE_URL=jdbc:postgresql://db.[ref].supabase.co:5432/postgres?sslmode=require
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=[supabase-db-password]

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_secure_random_string_at_least_32_chars

# ── CORS (URL do frontend) ────────────────────────────────────────────────
# Local: http://localhost:3000
# Produção: https://your-app.vercel.app
CORS_ALLOWED_ORIGIN=http://localhost:3000

# ── Discord (opcional) ────────────────────────────────────────────────────
# DISCORD_WEBHOOK_REPORTS=https://discord.com/api/webhooks/...
